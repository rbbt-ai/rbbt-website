{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rbbtlab-website",
  "compatibility_date": "2025-05-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "rbbtlab.ai", "custom_domain": true },
    { "pattern": "www.rbbtlab.ai", "custom_domain": true }
  ],
  "workers_dev": false,
  "observability": {
    "enabled": true
  }
}
